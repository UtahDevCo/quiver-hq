#!/bin/bash
# qcontrol - Management script for Quiver Controller

PROJECT_ROOT="/home/chris/dev/quiver-hq"
BINARY="$PROJECT_ROOT/controller"
LOG_FILE="$PROJECT_ROOT/controller.log"
ENV_FILE="$PROJECT_ROOT/.env.local"
PID_FILE="$PROJECT_ROOT/controller.pid"

build() {
    echo "Building Quiver Controller..."
    if (cd "$PROJECT_ROOT" && go build -o controller ./cmd/controller/main.go); then
        echo "Build successful."
    else
        echo "Build failed!"
        exit 1
    fi
}

start() {
    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "Controller is already running (PID $(cat "$PID_FILE"))."
    else
        echo "Starting Quiver Controller..."
        if [ -f "$ENV_FILE" ]; then
            export $(grep -v '^#' "$ENV_FILE" | xargs)
        fi
        nohup "$BINARY" > "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        echo "Started with PID $!"
    fi
}

stop() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        echo "Stopping Quiver Controller (PID $PID)..."
        kill "$PID" && rm "$PID_FILE" && echo "Stopped."
    else
        echo "PID file not found. Attempting pkill..."
        pkill -x "controller" && echo "Stopped via pkill." || echo "Not running."
    fi
}

case "$1" in
    build)
        build
        ;;
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        sleep 1
        if [[ "$2" == "--build" ]]; then
            build
        fi
        start
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
            echo "Controller is running (PID $(cat "$PID_FILE"))."
        else
            echo "Controller is stopped."
        fi
        ;;
    logs)
        tail -f "$LOG_FILE"
        ;;
    linger-enable)
        echo "Enabling linger for user $USER..."
        sudo loginctl enable-linger "$USER"
        echo "Linger enabled. User services will now persist after logout."
        ;;
    linger-disable)
        echo "Disabling linger for user $USER..."
        sudo loginctl disable-linger "$USER"
        echo "Linger disabled."
        ;;
    *)
        echo "Usage: $0 {build|start|stop|restart [--build]|status|logs|linger-enable|linger-disable}"
        exit 1
esac
