# Caddy Configuration for Quiver HQ
# Reverse proxy for services running on localhost with TLS via Let's Encrypt

# Global settings
{
  # Email for Let's Encrypt notifications
  email chris@chrisesplin.com

  # Optional: Uncomment to use Let's Encrypt staging (for testing)
  # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ============================================================================
# SECTION 1: Public Routes (via Tailscale Funnel + HTTPS)
# ============================================================================
# These are served publicly on the internet via Tailscale Funnel.
# Use these routes for services you want to expose publicly.

# Example: api.chrisesplin.com -> localhost:3000
# Uncomment and modify as needed:
# api.chrisesplin.com {
#   reverse_proxy localhost:3000
#   # Optional: Add Tailscale Funnel directive if you want public access
#   # tls_issuer acme
# }

# ============================================================================
# SECTION 2: Tailscale VPN Routes (HTTPS over Tailscale network)
# ============================================================================
# These are only accessible when connected to your Tailscale network.
# Use quiver-pn54.ts.net (Tailscale MagicDNS name) or your machine's IP.

# Replace TAILSCALE_IP with your actual Tailscale IP (e.g., 100.x.x.x)
# Or use quiver-pn54.ts.net once Tailscale MagicDNS is enabled

# Example: internal.chrisesplin.com -> localhost:3000
# When accessed from Tailscale network, add to /etc/hosts or use MagicDNS:
# 100.x.x.x internal.chrisesplin.com
# OR set up Tailscale DNS to resolve *.chrisesplin.com to this machine

# ============================================================================
# SECTION 3: Service Templates
# ============================================================================

# Template 1: Simple Reverse Proxy (no auth)
# my-service.chrisesplin.com {
#   reverse_proxy localhost:5000
#   # Automatic HTTPS with Let's Encrypt
# }

# Template 2: With Basic Auth
# secure-service.chrisesplin.com {
#   reverse_proxy localhost:5001
#   basicauth {
#     /api chris PASSWORD_HASH
#   }
# }

# Template 3: With Path Routing
# multi-service.chrisesplin.com {
#   reverse_proxy /api/* localhost:3000
#   reverse_proxy /web/* localhost:4000
#   reverse_proxy /* localhost:5000
# }

